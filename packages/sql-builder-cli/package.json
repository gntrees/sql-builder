{
  "name": "@gntrees/sql-builder-cli",
  "version": "0.0.1",
  "description": "SQL to query builder converter for gntrees-sql-builder",
  "author": "gntrees",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "bin": {
    "sql-builder-cli": "./dist/esm/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gntrees/gntrees-sql-builder.git"
  },
  "keywords": [
    "postgresql",
    "sql",
    "query-builder",
    "converter",
    "cli",
    "typescript"
  ],
  "scripts": {
    "prebuild": "node scripts/sync.mjs && node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run prebuild && bun run build:cjs && bun run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "test": "rm -rf test-dumps/* && bun run tests/run-tests.ts",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@pgsql/types": "^17.6.2",
    "kysely": "^0.27.6",
    "kysely-codegen": "^0.19.0",
    "pgsql-parser": "^17.6.2",
    "pg": "^8.13.3",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "@gntrees/sql-builder": "^0.0.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.13",
    "@types/bun": "latest"
  }
}
