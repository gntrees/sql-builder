{
  "name": "@gntrees/sql-builder",
  "version": "0.0.5",
  "description": "PostgreSQL query builder with fluent TypeScript API",
  "main": "./dist/cjs/pg.js",
  "module": "./dist/esm/pg.js",
  "types": "./dist/cjs/pg.d.ts",
  "type": "module",
  "exports": {
    "./pg": {
      "types": "./dist/cjs/pg.d.ts",
      "import": "./dist/esm/pg.js",
      "require": "./dist/cjs/pg.js"
    },
    "./pg/format": {
      "types": "./dist/cjs/pg/format.d.ts",
      "import": "./dist/esm/pg/format.js",
      "require": "./dist/cjs/pg/format.js"
    },
    "./pg/builder": {
      "types": "./dist/cjs/pg/builder.d.ts",
      "import": "./dist/esm/pg/builder.js",
      "require": "./dist/cjs/pg/builder.js"
    },
    "./pg/functions": {
      "types": "./dist/cjs/pg/functions.d.ts",
      "import": "./dist/cjs/pg/functions.js",
      "require": "./dist/cjs/pg/functions.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "postgresql",
    "query-builder",
    "sql",
    "typescript",
    "bun",
    "database"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gntrees/gntrees-sql-builder.git"
  },
  "license": "MIT",
  "author": "gntrees",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "pgsql-parser": "^17.9.1",
    "typescript": "^5.9.3",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "private": false,
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "pg": "^8.16.3"
  },
  "scripts": {
    "prebuild": "node scripts/sync.mjs && node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run prebuild && bun run build:cjs && bun run build:esm",
    "build:cjs": "NODE_OPTIONS='--max-old-space-size=8192' tsc -p tsconfig.cjs.json",
    "build:esm": "NODE_OPTIONS='--max-old-space-size=8192' tsc -p tsconfig.esm.json",
    "generate": "bun run src/dialects/pg/extract.ts",
    "test": "bun test src/dialects/pg/tests/*.test.ts",
    "test:network": "bun test src/dialects/pg/tests/network-functions.test.ts"
  }
}
