{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "CommonJS",
        "outDir": "./dist/cjs",
        "rootDir": ".",
        "declaration": true,
        "declarationDir": "./dist/cjs",
        "emitDeclarationOnly": false,
        "allowImportingTsExtensions": false,
        "verbatimModuleSyntax": false
    },
    "include": ["index.ts", "pg.ts", "pg/builder.ts", "pg/format.ts", "pg/functions.ts", "src/**/*.ts"],
    "exclude": ["src/dialects/pg/tests/**", "**/*.test.ts", "src/dialects/pg/extract.ts"]
}
